# NOcap — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# See CLAUDE.md for full documentation on each variable.

# ─── Supabase (Client — safe to expose) ──────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...          # anon/public key
VITE_SUPABASE_PROJECT_ID=<project-ref>

# ─── Push Notifications (Client — safe to expose) ────────────────────────────
VITE_VAPID_PUBLIC_KEY=                         # from web-push key generation

# ─── Edge Function Secrets (set in Supabase Dashboard → Settings → Edge Functions)
# These are NOT used in the client — they live in Supabase only.
#
# Auto-injected by Supabase (do NOT set manually):
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#
# RaudhahPay — Collection (top-ups via FPX)
#   RAUDHAHPAY_API_KEY=
#   RAUDHAHPAY_COLLECTION_CODE=
#   RAUDHAHPAY_SECRET_KEY=
#
# RaudhahPay — Disbursement (automated bank payouts)
#   RAUDHAHPAY_DISBURSEMENT_KEY=
#   RAUDHAHPAY_DISBURSEMENT_SECRET=
#   RAUDHAHPAY_CALLBACK_URL=https://<project-ref>.supabase.co/functions/v1/withdrawal-disbursement-webhook
#
# SendGrid — Transactional email
#   SENDGRID_API_KEY=
#   SENDGRID_FROM_EMAIL=noreply@nocap.life
#
# LiveKit — Live shopping
#   LIVEKIT_API_KEY=
#   LIVEKIT_API_SECRET=
#   LIVEKIT_URL=wss://your-project.livekit.cloud
#
# Push notifications (server-side VAPID)
#   VAPID_PUBLIC_KEY=
#   VAPID_PRIVATE_KEY=
#   VAPID_SUBJECT=mailto:hello@nocap.life
#
# Internal
#   CRON_SECRET=                               # random secret for cron job auth
